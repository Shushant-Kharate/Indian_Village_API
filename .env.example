# Village API - Environment Configuration
# Copy this file to .env and fill in with actual values

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=indian_villages
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h

# ============================================
# API Key Configuration
# ============================================
API_KEY_PREFIX=ak_
API_SECRET_PREFIX=as_
API_KEY_LENGTH=32

# ============================================
# Rate Limiting Configuration
# ============================================
RATE_LIMIT_WINDOW_MINUTES=1
RATE_LIMIT_CHECK_INTERVAL_MINUTES=60

# ============================================
# SMTP Configuration (Email Service)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM=noreply@villageapi.com

# Admin email for receiving new registration notifications
ADMIN_EMAIL=admin@villageapi.com

# ============================================
# Frontend URLs (for email links)
# ============================================
DASHBOARD_URL=http://localhost:5173
ADMIN_URL=http://localhost:5173/admin
FRONTEND_URL=http://localhost:5173

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
CORS_CREDENTIALS=true

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# ============================================
# Redis Configuration (Optional - for caching)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# Payment Configuration (Stripe)
# ============================================
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# AWS Configuration (Optional - for file storage)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=village-api-bucket

# ============================================
# Vercel Deployment Configuration
# ============================================
VERCEL_ENV=production
VERCEL_URL=your-production-domain.vercel.app

# ============================================
# Analytics Configuration
# ============================================
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90

# ============================================
# Security Configuration
# ============================================
BCRYPT_ROUNDS=10
HIDE_POWERED_BY=true
ENABLE_SECURITY_HEADERS=true

# ============================================
# Maintenance Mode (when true, API returns 503)
# ============================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=API is under maintenance. Please try again later.
